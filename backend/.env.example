# =============================================================================
# Crucible Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
#   cp .env.example .env
# =============================================================================

# --- Application -----------------------------------------------------------
APP_ENV=development
APP_PORT=8080
RUST_LOG=crucible_backend=debug,tower_http=debug,sqlx=warn
RUST_BACKTRACE=1
RUST_VERSION=1.78

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=crucible
POSTGRES_PASSWORD=crucible_secret
POSTGRES_DB=crucible_db
POSTGRES_PORT=5432

# Database pool configuration
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=2
DATABASE_CONNECT_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=600

# --- Redis ------------------------------------------------------------------
REDIS_PASSWORD=crucible_redis_secret
REDIS_PORT=6379
REDIS_DB=0
REDIS_POOL_SIZE=5

# --- Security ---------------------------------------------------------------
JWT_SECRET=dev-jwt-secret-change-in-production
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Bearer tokens for privileged endpoints (admin + config reload/logs/etc).
# Requests to /api/v1/admin/* and /api/config* must send
# `Authorization: Bearer <token>`. ADMIN_API_TOKEN grants admin access;
# if unset, those routes reject all requests (locked down by default).
ADMIN_API_TOKEN=dev-admin-token-change-in-production
# Optional: a token that authenticates but is NOT authorized for admin routes.
OPERATOR_API_TOKEN=

# --- Dev Tools (optional, use `docker compose --profile dev-tools up`) ------
PGADMIN_EMAIL=admin@crucible.dev
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
REDIS_COMMANDER_PORT=8081
